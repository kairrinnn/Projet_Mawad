generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  MANAGER
  CASHIER
}

enum SaleType {
  SALE
  REFUND
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  pinCode       String?
  role          UserRole   @default(CASHIER)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  accounts      Account[]
  products      Product[]
  sales         Sale[]
  sessions      Session[]
  suppliers     Supplier[]
  cashDrawers   CashDrawer[]
  expenses      Expense[]
  categories    Category[]
  stockEntries  StockEntry[]
  stockMovements StockMovement[]
  auditLogs     AuditLog[]
}

// ... existing models ...

model AuditLog {
  id          String   @id @default(cuid())
  action      String   // e.g., "CREATE_SALE", "REFUND_SALE", "UPDATE_PRODUCT", "MANAGER_ACCESS"
  entityType  String?  // e.g., "Sale", "Product", "Expense", "StockEntry"
  entityId    String?
  details     String?  @db.Text
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model CashDrawer {
  id           String   @id @default(cuid())
  userId       String
  startingCash Decimal @default(500) @db.Decimal(12, 2)
  date         DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Supplier {
  id        String    @id @default(cuid())
  name      String
  contact   String?
  userId    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Product {
  id                String    @id @default(cuid())
  barcode           String?
  name              String
  salePrice         Decimal @db.Decimal(12, 2)
  costPrice         Decimal @db.Decimal(12, 2)
  weightSalePrice   Decimal? @db.Decimal(12, 2)
  weightCostPrice   Decimal? @db.Decimal(12, 2)
  canBeSoldByWeight Boolean   @default(false)
  stock             Float     @default(0)
  lowStockThreshold Float     @default(5)
  category          String?   // À supprimer après migration vers categoryId
  categoryId        String?
  categoryRef       Category? @relation(fields: [categoryId], references: [id])
  description       String?
  image             String?
  stockEntries      StockEntry[]
  stockMovements    StockMovement[]
  sales             Sale[]
  supplierId        String?
  userId            String?
  isArchived        Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  supplier          Supplier? @relation(fields: [supplierId], references: [id])

  @@unique([barcode, userId])
}

model Sale {
  id           String   @id @default(cuid())
  productId    String
  quantity     Float
  salePrice    Decimal @db.Decimal(12, 2)
  costPrice    Decimal @db.Decimal(12, 2)
  totalPrice   Decimal @default(0) @db.Decimal(12, 2)
  profit       Decimal @db.Decimal(12, 2)
  discount     Decimal @default(0) @db.Decimal(12, 2)
  type         SaleType @default(SALE)
  isRefunded   Boolean  @default(false)
  soldByWeight Boolean  @default(false)
  parentId     String?
  userId       String?
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product      Product  @relation(fields: [productId], references: [id])
}

model Expense {
  id          String   @id @default(cuid())
  type        String   // Salary, Utility, Rent, Internet, Stock, Daily
  amount      Decimal @db.Decimal(12, 2)
  description String?
  date        DateTime @default(now())
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StockEntry {
  id          String   @id @default(cuid())
  productId   String
  quantity    Float    // Number of units or weight added
  costPrice   Decimal @db.Decimal(12, 2) // Price per unit at time of entry (snapshot)
  totalCost   Decimal @db.Decimal(12, 2) // quantity * costPrice
  date        DateTime @default(now())
  userId      String
  product     Product  @relation(fields: [productId], references: [id])
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum MovementType {
  IN          // Approvisionnement
  OUT         // Vente
  ADJUSTMENT  // Ajustement manuel
  LOSS        // Perte / Casse
  RETURN      // Retour client
}

model StockMovement {
  id          String       @id @default(cuid())
  productId   String
  type        MovementType
  quantity    Float        // Toujours positif, le sens est donné par le type
  oldStock    Float        // Stock avant mouvement
  newStock    Float        // Stock après mouvement
  reason      String?
  userId      String
  product     Product      @relation(fields: [productId], references: [id])
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())

  @@index([productId])
  @@index([userId])
}
model Category {
  id        String    @id @default(cuid())
  name      String
  userId    String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([name, userId])
}
